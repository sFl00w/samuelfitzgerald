<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
    <!-- $title = Contact -->
    <!-- @include assets/meta-head.kit -->
</head>
<body>


<!-- @include assets/header.kit -->


<!-- ========= Hero Section ========= -->
<section class="hero-section after-header" style="height: 400px;" data-disable-resize>
    <!-- Background Image -->
    <div class="background image" style="background-image: url('images/big-backgrounds/bg5.jpg');" data-parallax="-0.5"></div>

    <!-- Section content -->
    <div class="content remove-padding"><div class="content-inner">
        <h1 class="bold">Contact</h1>
    </div></div>
</section>


<!-- ========= Form Section ========= -->
<section class="container big-padding"><div class="row">

    <!-- Text -->
    <div class="col-xs-12 col-sm-4" style="padding-right: 50px;">
        <h3>Say Hello</h3>

        <p>Parturient reprehenderit aspernatur proin! Impedit voluptatum, cillum. Qui! Etiam iure debitis culpa provident tempor ab incidunt autem vel hendrerit aut.</p>

        <p class="nolast">Eros inventore aliquid? Expedita platea dis incididunt dolores, deleniti? Totam ullam a, donec, orci pulvinar platea consequat ut hac voluptatem.</p>
    </div>

    <!-- Form -->
    <div class="col-xs-12 col-sm-8">
        <form id="contact_form" action="php/contact.php" method="post">

            <!-- Success message -->
            <div class="alert alert-success hide-soft">
                <strong>Well done!</strong> Your message sent! Thank you ;)
            </div>

            <!-- Error message -->
            <div class="alert alert-danger hide-soft">
                <strong>Something wrong!</strong> <span></span>
            </div>

            <!-- Form First row -->
            <div class="row">
                <div class="form-group col-xs-12 col-sm-6">
                    <label for="fullname_field">Full Name*</label>
                    <input type="text" class="form-control" id="fullname_field" name="fullname" required/>
                </div>

                <div class="form-group col-xs-12 col-sm-6">
                    <label for="email_field">Email*</label>
                    <input type="email" class="form-control" id="email_field" name="email" required/>
                </div>
            </div>

            <!-- Second row -->
            <div class="row">
                <div class="form-group col-xs-12 col-sm-6">
                    <label for="company_field">Company*</label>
                    <input type="text" class="form-control" id="company_field" name="company" required/>
                </div>

                <div class="form-group col-xs-12 col-sm-6">
                    <label for="phone_field">Phone</label>
                    <input type="text" class="form-control" id="phone_field" name="phone" />
                </div>
            </div>

            <!-- Third row -->
            <div class="form-group">
                <label for="message_field">Message*</label>
                <textarea id="message_field" class="form-control" rows="7" name="message" required></textarea>
            </div>

            <!-- Buttons -->
            <div class="form-group"><button type="submit" class="btn btn-default btn-long text-uppercase">Submit</button></div>
        </form>

    </div>
</div></section>


<!-- ========= Contacts Section ========= -->
<section class="container-wrap secondary-bg">
    <ul class="icons-list contacts block-grid-xs-1 block-grid-sm-3">
        <li><div class="inner-content">
            <i class="entypo phone"></i>
            <p class="descr">(619) 450-2549</p>
        </div></li>

        <li><div class="inner-content">
            <i class="entypo location"></i>
            <p class="descr">629 J street #207 <br/> San Diego, CA. 92101</p>
        </div></li>

        <li><div class="inner-content">
            <i class="entypo mail"></i>
            <p class="descr">support@wphunters.com</p>
        </div></li>
    </ul>
</section>


<!-- ========= Map Section ========= -->
<section class="place-map" style="height: 400px;" data-lat="32.709423" data-long="-117.158567">
    <b>660 J Street</b><br/>
    <b>San Diego, CA 92101</b><br/>
    USA
</section>


<!-- @include assets/footer.kit -->


</body>
</html>