<body>


<!-- @include assets/header.kit -->


<!-- ========= Hero Section ========= -->
<section class="hero-section after-header" style="height: 600px;" data-disable-resize>
    <!-- Background Image -->
    <div class="background image" style="background-image: url('images/portfolio/big1_1.jpg');" data-parallax="-0.5"></div>

    <!-- Section content -->
    <div class="content remove-padding"><div class="content-inner">
        <h1 class="bold">Musical band project</h1>
        <p>Short description about project, in one-two sentences.</p>
        <p><a class="btn btn-white text-uppercase" href="#">See it live</a></p>
    </div></div>
</section>


<!-- ========= "The task" section ========= -->
<section class="container big-padding"><div class="row">
    <div class="col-xs-12 col-md-4"><h2 class="nolast">The task</h2></div>

    <div class="col-xs-12 col-md-4"><p class="nolast">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p></div>

