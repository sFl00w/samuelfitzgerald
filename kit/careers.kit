<body>


<!-- @include assets/header.kit -->


<!-- ========= Hero Section ========= -->
<section class="hero-section after-header" style="height: 500px;" data-disable-resize>
    <!-- Background Image -->
    <div class="background image" style="background-image: url('images/big-backgrounds/bg4.jpg');" data-parallax="-0.5"></div>

    <!-- Section content -->
    <div class="content remove-padding"><div class="content-inner">
        <h1 class="bold">Careers</h1>
    </div></div>
</section>


<!-- ========= Filters Section ========= -->
<nav class="isotope-filter"><div class="container">
    <ul class="desktop-filter hidden-xs convert-to-select" data-isotope-id="careers">
        <li class="active"><a href="#" data-filter="*">All cities</a></li>
        <li><a href="#" data-filter=".city-new-york">New York</a></li>
        <li><a href="#" data-filter=".city-chisinau">Chisinau</a></li>
        <li><a href="#" data-filter=".city-london">London</a></li>
    </ul>
</div></nav>


<!-- ========= Careers list ========= -->
<section class="container">
    <ul class="careers-list isotope big-padding block-grid-xs-1 block-grid-sm-2 block-grid-md-3" data-isotope-id="careers">
