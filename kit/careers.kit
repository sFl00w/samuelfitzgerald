<!-- ========= Quote section with image background ========= -->
<section class="container-wrap quote-with-bg" style="background-image: url('images/big-backgrounds/forest2.jpg');" data-parallax="-0.3">
    <div class="container big-padding"><blockquote class="bigquote">
        <i class="entypo quote top"></i>
        <p>Creativity is just connecting things. When you ask creative people how they did something, they feel a little guilty because they didn't really do it, they just saw something.</p>
        <i class="entypo quote bottom"></i>

        <footer>Steve Jobs</footer>
    </blockquote></div>
</section>


<!-- @include assets/footer.kit -->


