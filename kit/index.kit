<body>


<!-- @include assets/header.kit -->


<!-- ========= Hero Section ========= -->
<section class="hero-section">
    <!-- Background image -->
    <div class="background image" style="background-image: url('images/bg-video.jpg');"></div>

    <!-- Background video -->
    <div class="background" data-vide-bg="images/bg-video" data-parallax="-0.5" data-parallax-type="elem"></div>

    <!-- Section content -->
    <div class="content"><div class="content-inner">
        <h1><strong>Creative</strong> portfolio</h1>
        <p>Show your works in a beautiful way</p>
        <p><a class="btn btn-white-primary text-uppercase" href="portfolio.html">Portfolio</a></p>
    </div></div>

    <!-- "Discover" button -->
    <div class="discover">
        <a href="#about" class="discover-btn" data-toggle="smoothscroll">Discover <i class="entypo down-open-big"></i></a>
    </div>
</section>


<!-- ========= Description Section ========= -->
<section class="container-wrap about" id="about">
    <div class="container big-padding">
        <h2>Axis is a digital agency with office in Chisinau</h2>

        <p>We help our clients build or improve applications for all platforms and screen <br/> sizes. We develop digital communication campaigns to inspire supporters <br/> for social action, political campaigns, not-for-profits and brands.</p>

        <nav>
            <a class="btn btn-default text-uppercase" href="portfolio.html">Portfolio</a>
            <a class="btn btn-default text-uppercase" href="services.html">Services</a>
        </nav>
    </div>
</section>


<!-- ========= Works Section ========= -->
<section class="portfolio-tiles row">
