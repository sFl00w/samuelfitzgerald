<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
    <!-- $title = News -->
    <!-- @include assets/meta-head.kit -->
</head>
<body>


<!-- @include assets/header.kit -->


<!-- ========= Hero Section ========= -->
<section class="hero-section after-header" style="height: 400px;" data-disable-resize>
    <!-- Background Image -->
    <div class="background image" style="background-image: url('images/big-backgrounds/church.jpg');" data-parallax="-0.5"></div>

    <!-- Section content -->
    <div class="content remove-padding"><div class="content-inner">
        <h1 class="bold">News</h1>
    </div></div>
</section>


<div class="row nomargin">
    <!-- ========= News Section ========= -->
    <main class="news-list col-sm-7 col-md-8" data-mh="newspage">
        <article>
            <div class="main-image"><img src="images/news/1.jpg" alt=""/></div>
            <time datetime="2014-12-05" pubdate>December 5, 2014</time>
            <h1 class="title">Sell a Product, Don’t Settle for Change</h1>
            <span class="btn btn-default">READ MORE</span>
            <a class="link-overlay" href="news-single.html"></a>
        </article>

        <article>
            <div class="main-image"><img src="images/news/2.jpg" alt=""/></div>
            <time datetime="2014-11-20" pubdate>November 20, 2014</time>
            <h1 class="title">5 Affordable Project Management Tools for Nonprofits</h1>
            <span class="btn btn-default">READ MORE</span>
            <a class="link-overlay" href="news-single.html"></a>
        </article>

        <article>
            <div class="main-image"><img src="images/news/3.jpg" alt=""/></div>
            <time datetime="2014-11-20" pubdate>November 20, 2014</time>
            <h1 class="title">10 ideas to change the world</h1>
            <span class="btn btn-default">READ MORE</span>
            <a class="link-overlay" href="news-single.html"></a>
        </article>
    </main>


    <!-- ========= Sidebar ========= -->
    <aside class="sidebar secondary-bg col-sm-5 col-md-4" data-mh="newspage">

        <!-- Subscribe widget -->
        <section>
            <h1>Subscribe to our newsletter</h1>

            <!-- Your mailchimp subscribe URL -->
            <form id="subscribe_form" class="form-inline" action="http://bbdesign.us9.list-manage.com/subscribe/post" method="post">
                <input type="hidden" name="u" value="1368c473b42d831e481262a9c">
                <input type="hidden" name="id" value="1b59f188b7">
                <div class="hidden-form-view"><input type="text" name="b_1368c473b42d831e481262a9c_1b59f188b7" value="" tabindex="-1"></div>

                <!-- Success message -->
                <div class="alert alert-success alert-warning hide-soft">
                    <strong>Almost done!</strong> To complete the subscription process, please click the link in the email we just sent you.
                </div>

                <!-- Error message -->
                <div class="alert alert-danger hide-soft">
                    <strong>Something wrong!</strong> <span></span>
                </div>

                <!-- Form fields -->
                <div class="input-group col-xs-12">
                    <input type="email" id="email_field" name="EMAIL" class="form-control" placeholder="Your email" required/>
                    <span class="input-group-btn">
                        <button class="btn btn-default text-uppercase">Subscribe</button>
                    </span>
                </div>
            </form>
        </section>


        <!-- Socials widget -->
        <section>
            <h1>Follow us</h1>

            <ul class="socials-list invert">
                <li><a href="#"><i class="entypo facebook"></i></a></li>
                <li><a href="#"><i class="entypo twitter"></i></a></li>
                <li><a href="#"><i class="entypo gplus"></i></a></li>
                <li><a href="#"><i class="entypo linkedin"></i></a></li>
                <li><a href="#"><i class="entypo dribbble"></i></a></li>
            </ul>
        </section>


        <!-- Popular posts -->
        <section class="post-list">
            <h1>Popular posts</h1>

            <article>
                <div class="img-col"><div style="background-image: url('images/news/thumb1.jpg');"></div></div>
                <div class="post-info-col">
                    <time datetime="2014-12-05">December 5, 2014</time>
                    <h1>Ultimate guide to Japanese beef</h1>
                </div>
                <a class="link-overlay" href="news-single.html">See more</a>
            </article>

            <article>
                <div class="img-col"><div style="background-image: url('images/news/thumb2.jpg');"></div></div>
                <div class="post-info-col">
                    <time datetime="2014-12-05">December 5, 2014</time>
                    <h1>How to eat sushi like a master</h1>
                </div>
                <a class="link-overlay" href="news-single.html">See more</a>
            </article>

            <article>
                <div class="img-col"><div style="background-image: url('images/news/thumb3.jpg');"></div></div>
                <div class="post-info-col">
                    <time datetime="2014-12-05">December 5, 2014</time>
                    <h1>Brisbane: Where living is easy</h1>
                </div>
                <a class="link-overlay" href="news-single.html">See more</a>
            </article>
        </section>


        <!-- Tags widget -->
        <section>
            <h1>Tags</h1>

            <div class="tags-list">
                <a href="#">Travel</a> <a href="#">Lifestyle</a> <a href="#">Food</a>
            </div>
        </section>


        <!-- Archive widget -->
        <section>
            <h1>Archive</h1>

            <ul>
                <li><a href="#">November 2014</a></li>
                <li><a href="#">October 2014</a></li>
                <li><a href="#">September 2014</a></li>
                <li><a href="#">August 2014</a></li>
            </ul>
        </section>
    </aside>
</div>


<!-- @include assets/footer.kit -->


</body>
</html>